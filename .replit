modules = ["python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["geckodriver"]

[workflows]
runButton = "Run"

[[workflows.workflow]]
name = "Run"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m pip install -r requirements.txt"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python test_totp.py"

[workflows.workflow.metadata]
outputType = "console"
